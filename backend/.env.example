# SQLMind Backend Environment Variables
# Copy to .env and fill in values

# App
ENVIRONMENT=development
DEBUG=true

# Security — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_secret_key_here

# Database
POSTGRES_URL=postgresql://sqlmind:sqlmind_dev@localhost:5432/sqlmind
ASYNC_POSTGRES_URL=postgresql+asyncpg://sqlmind:sqlmind_dev@localhost:5432/sqlmind
REDIS_URL=redis://localhost:6379

# AI Keys — at least one required
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=AIza...

# LLM Config
DEFAULT_LLM=openai
LLM_MODEL=gpt-4o

# Guardrails
ENABLE_PII_DETECTION=true
ENABLE_INJECTION_DETECTION=true

# CORS — add your frontend URL
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
